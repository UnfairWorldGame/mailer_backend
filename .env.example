PORT=3001
NODE_ENV=development
# Comma-separated for multiple domains, e.g. https://mailiq.app,https://www.mailiq.app
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mailer?retryWrites=true&w=majority

# JWT authentication
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Boot fails fast on an empty, short (<32 char), or well-known sample secret —
# including the placeholder that used to live here.
JWT_SECRET=

# Encrypts Gmail App Passwords at rest (AES-256-GCM). Unset = stored in
# PLAINTEXT, which hands anyone with database read access working SMTP
# credentials that send as your users. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Back this value up somewhere outside the platform: without it the stored
# credentials cannot be decrypted. After setting it on an existing deployment,
# run: node scripts/encrypt-credentials.mjs
CREDENTIAL_ENCRYPTION_KEY=

# Sessions are a short-lived access token plus a rotating refresh token.
# Keep the access TTL small: it is the window in which a stolen token is usable,
# and revocation (password change, sign-out-everywhere) is immediate regardless.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# JWT_EXPIRES_IN is no longer read — ACCESS_TOKEN_TTL replaces it.

# Rate limits. Auth limiters are backed by MongoDB so they hold across
# instances; the default in-memory store made them per-process, which on
# Cloud Run with --max-instances=10 meant 10x the intended limit.
AUTH_RATE_LIMIT_MAX=20
LOGIN_RATE_LIMIT_MAX=10
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
RESEND_VERIFY_RATE_LIMIT_MAX=5
# Set to 1 ONLY for local load testing. Rate limiting is otherwise always on,
# including in development — the previous NODE_ENV-based skip was fail-open.
RATE_LIMIT_DISABLED=

# Comma-separated emails that always have admin access (must match registered login email)
ADMIN_EMAILS=admin@example.com

# Auth email (password reset + email verification) — sent from this Gmail account.
# Paste the App Password with or without Google's display spaces; they are
# stripped, because Gmail SMTP rejects "abcd efgh ijkl mnop" with 535-5.7.8.
# The server probes this at boot and logs "[auth-mail] SMTP ready" or a failure.
PASSWORD_RESET_SMTP_EMAIL=mailiq.office@gmail.com
PASSWORD_RESET_SMTP_APP_PASSWORD=
PASSWORD_RESET_FROM_NAME=MAILIQ

# Contact form & credit purchase inquiries — team inbox (also notifies ADMIN_EMAILS)
CONTACT_INBOX_EMAIL=mailiq.office@gmail.com
INQUIRY_RATE_LIMIT_MAX=10
BUY_CREDITS_RATE_LIMIT_MAX=2
# REMOVED (read by nothing): CREDIT_REQUEST_COOLDOWN_HOURS=24

# Billing & quotas (Phase 1 — manual credit grants)
FREE_DAILY_CREDITS=100

RATE_LIMIT_MAX=2000
UPLOAD_RATE_LIMIT_MAX=30

# Email sending engine
GMAIL_PER_ACCOUNT_DELAY_MS=5000
EMAIL_SEND_DELAY_MS=5000
EMAIL_SEND_MIN_DELAY_MS=0
EMAIL_SEND_MAX_DELAY_MS=60000
GMAIL_DAILY_LIMIT_PER_ACCOUNT=500
GMAIL_HOURLY_LIMIT_PER_ACCOUNT=100
EMAIL_MAX_RETRIES_PER_RECIPIENT=3
EMAIL_RETRY_BASE_DELAY_MS=5000
EMAIL_RETRY_MAX_DELAY_MS=300000
EMAIL_CLAIM_STALE_MS=300000
EMAIL_CAMPAIGN_LOCK_STALE_MS=600000
EMAIL_PROGRESS_SYNC_EVERY=10

# Gemini AI (email writing & rewrite)
# gemini-2.0-flash is shut down — use 2.5 Flash on free tier
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-1.5-flash
AI_RATE_LIMIT_MAX=30

# Billing / credits
# Payment is arranged off-platform: the user requests a pack, an admin shares
# payment details and then credits the account. These surface in the upgrade
# dialog so a blocked user knows who to contact.
BILLING_CONTACT_EMAIL=mailiq.office@gmail.com
BILLING_CONTACT_PHONE=
BILLING_CONTACT_WHATSAPP=
BILLING_CONTACT_HOURS=Mon–Sat, 10am–7pm IST
BILLING_RESPONSE_TIME=Usually within a few hours
# Ceiling on a single admin credit grant (reversal is manual, so cap the blast
# radius of a mistyped amount).
MAX_GRANT_CREDITS=1000000

# Transactional email delivery
# Every transactional email is persisted to an outbox before sending, so a
# failure is retried rather than lost. This is the retry sweep interval.
EMAIL_SWEEP_INTERVAL_MS=120000
# Who receives admin-facing alerts (new signups, credit grants/refunds, account
# changes). Falls back to ADMIN_EMAILS + CONTACT_INBOX_EMAIL when unset.
ADMIN_NOTIFY_EMAILS=
