PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mailer?retryWrites=true&w=majority

# JWT authentication
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
AUTH_RATE_LIMIT_MAX=20
FORGOT_PASSWORD_RATE_LIMIT_MAX=5

# Comma-separated emails that always have admin access (must match registered login email)
ADMIN_EMAILS=admin@example.com

# Password reset emails — sent only from this Gmail account (app password required)
PASSWORD_RESET_SMTP_EMAIL=mailiq.office@gmail.com
PASSWORD_RESET_SMTP_APP_PASSWORD=
PASSWORD_RESET_FROM_NAME=MAILIQ

# Contact form & credit purchase inquiries (defaults to PASSWORD_RESET_SMTP_EMAIL or hello@mailiq.app)
CONTACT_INBOX_EMAIL=hello@mailiq.app
INQUIRY_RATE_LIMIT_MAX=10
BUY_CREDITS_RATE_LIMIT_MAX=2
CREDIT_REQUEST_COOLDOWN_HOURS=24

# Billing & quotas (Phase 1 — manual credit grants)
FREE_DAILY_EMAIL_LIMIT=100

RATE_LIMIT_MAX=2000
UPLOAD_RATE_LIMIT_MAX=30

# Email sending engine
GMAIL_PER_ACCOUNT_DELAY_MS=5000
EMAIL_SEND_DELAY_MS=5000
EMAIL_SEND_MIN_DELAY_MS=0
EMAIL_SEND_MAX_DELAY_MS=60000
GMAIL_DAILY_LIMIT_PER_ACCOUNT=500
GMAIL_HOURLY_LIMIT_PER_ACCOUNT=100
EMAIL_MAX_RETRIES_PER_RECIPIENT=3
EMAIL_RETRY_BASE_DELAY_MS=5000
EMAIL_RETRY_MAX_DELAY_MS=300000
EMAIL_CLAIM_STALE_MS=300000
EMAIL_CAMPAIGN_LOCK_STALE_MS=600000
EMAIL_PROGRESS_SYNC_EVERY=10

# Gemini AI (email writing & rewrite)
# gemini-2.0-flash is shut down — use 2.5 Flash on free tier
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-1.5-flash
AI_RATE_LIMIT_MAX=30
