PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mailer?retryWrites=true&w=majority
RATE_LIMIT_MAX=2000
UPLOAD_RATE_LIMIT_MAX=30

# Email sending engine
EMAIL_SEND_DELAY_MS=4000
EMAIL_SEND_MIN_DELAY_MS=1000
EMAIL_SEND_MAX_DELAY_MS=60000
GMAIL_DAILY_LIMIT_PER_ACCOUNT=500
GMAIL_HOURLY_LIMIT_PER_ACCOUNT=100
EMAIL_MAX_RETRIES_PER_RECIPIENT=3
EMAIL_RETRY_BASE_DELAY_MS=5000
EMAIL_RETRY_MAX_DELAY_MS=300000
EMAIL_CLAIM_STALE_MS=300000
EMAIL_CAMPAIGN_LOCK_STALE_MS=600000
EMAIL_PROGRESS_SYNC_EVERY=10
